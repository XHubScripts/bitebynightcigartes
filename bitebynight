task.spawn(function()
    while true do
        if not IsEnabled("esp_master", true) then
            task.wait(UI.GetValue("esp_refresh") or 2.5)
            continue
        end

        local Categories = GetFilteredTable()

        for CategoryName, Data in Categories do
            for _, Obj in Data.Objects do
                if not Obj or not Obj.Address then
                    continue
                end

                local DisplayName = CategoryName

                if CategoryName == "Killer" and Obj.Parent then
                    DisplayName = Obj.Parent.Name
                end

                if CategoryName == "Generator" then
                    local genModel = Obj.Parent
                    local progress = genModel and (genModel:GetAttribute("Progress") or 0) or 0
                    local ExistingTracker = ESP_Utility.TrackersToUpdate[Obj.Address]

                    if progress >= 100 then
                        if not LastCompletedGenerators[Obj.Address] then
                            LastCompletedGenerators[Obj.Address] = true
                            Notify("Generator Complete", (genModel and genModel.Name or "Generator") .. "finished", 3)
                        end

                        if IsEnabled("esp_remove_completed_gens", true) then
                            if ExistingTracker then
                                ExistingTracker:Destroy()
                            end
                            continue
                        end
                    else
                        LastCompletedGenerators[Obj.Address] = nil
                    end
                end

                local Tracker = ESP_Utility.NewTracker(Obj, DisplayName, Data.Color)
                if not Tracker then
                    continue
                end

                local showBoxes = IsEnabled("esp_show_boxes", true)
                if Tracker.Drawings.Square then
                    Tracker.Drawings.Square.Color = Data.Color
                    Tracker.Drawings.Square.Visible = showBoxes
                end

                if CategoryName == "Generator" then
                    if Tracker.Drawings.Square then
                        Tracker.Drawings.Square.Visible = false
                    end

                    if IsEnabled("esp_gen_progress", true) then
                        if not Tracker.Drawings["Progress"] then
                            local ProgressFunction = function()
                                local genModel = Obj.Parent
                                if not genModel then
                                    return ""
                                end

                                local progress = genModel:GetAttribute("Progress") or 0
                                return string.format("Progress: %d%%", progress)
                            end

                            Tracker:AddText("Progress", Color3.fromRGB(120, 255, 120), "Progress: 0%", ProgressFunction)
                        end

                        if Tracker.Drawings["Progress"] then
                            Tracker.Drawings["Progress"].Drawing.Color = Color3.fromRGB(120, 255, 120)
                            Tracker.Drawings["Progress"].Visible = true
                        end
                    elseif Tracker.Drawings["Progress"] then
                        Tracker.Drawings["Progress"].Visible = false
                    end
                end
            end
        end

        task.wait(UI.GetValue("esp_refresh") or 2.5)
    end
end)
