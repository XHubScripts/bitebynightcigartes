local URL = "https://raw.githubusercontent.com/artxficial/matchastuff/main/esp_utility.lua"
pcall(function()
    loadstring(game:HttpGet(URL))()
end)

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local GeneratorColor = Color3.fromRGB(120, 255, 120)
local BatteryColor = Color3.fromRGB(220, 232, 93)
local TrapColor = Color3.fromRGB(232, 102, 100)
local MinionColor = Color3.fromRGB(130, 55, 55)
local KillerColor = Color3.fromRGB(255, 150, 150)

local CompletedGenerators = {}
local GeneratorTrackers = {}
local GeneratorBoundsParts = {}
local StaticTrackers = {
    Killer = {},
    Trap = {},
    Battery = {},
    Minion = {}
}
local CurrentMapRef = nil

local function UIValue(key, default)
    if UI and UI.GetValue then
        local ok, value = pcall(function()
            return UI.GetValue(key)
        end)
        if ok and value ~= nil then
            return value
        end
    end
    return default
end

local function SetDrawingVisible(drawingObj, visible)
    if drawingObj and drawingObj.Drawing then
        drawingObj.Visible = visible
        drawingObj.Drawing.Visible = visible
    end
end

local function SetTrackerVisible(tracker, visible)
    if not tracker or not tracker.Drawings then
        return
    end

    for _, drawing in pairs(tracker.Drawings) do
        SetDrawingVisible(drawing, visible)
    end
end

local function DestroyBoundsPart(generatorModel)
    local part = GeneratorBoundsParts[generatorModel]
    if part then
        pcall(function()
            part:Destroy()
        end)
        GeneratorBoundsParts[generatorModel] = nil
    end
end

local function RemoveGeneratorTracker(generatorModel)
    local tracker = GeneratorTrackers[generatorModel]
    if tracker then
        pcall(function()
            tracker:Destroy()
        end)
        GeneratorTrackers[generatorModel] = nil
    end

    DestroyBoundsPart(generatorModel)
end

local function ResetRoundIfNeeded()
    local mapsFolder = Workspace:FindFirstChild("MAPS")
    local gameMap = mapsFolder and mapsFolder:FindFirstChild("GAME MAP")

    if gameMap ~= CurrentMapRef then
        CurrentMapRef = gameMap
        CompletedGenerators = {}

        for generatorModel in pairs(GeneratorTrackers) do
            RemoveGeneratorTracker(generatorModel)
        end
    end
end

local function IsGeneratorComplete(generatorModel)
    if not generatorModel or not generatorModel.Parent then
        return false
    end

    local progress = generatorModel:GetAttribute("Progress") or 0
    return progress >= 100
end

local function GetOrCreateGeneratorBoundsPart(generatorModel)
    if not generatorModel or not generatorModel.Parent then
        return nil
    end

    local boundPart = GeneratorBoundsParts[generatorModel]
    if boundPart and boundPart.Parent then
        local cf, size = generatorModel:GetBoundingBox()
        boundPart.CFrame = cf
        boundPart.Size = size + Vector3.new(1.6, 1.6, 1.6)
        return boundPart
    end

    local cf, size = generatorModel:GetBoundingBox()
    boundPart = Instance.new("Part")
    boundPart.Name = "__GeneratorBounds"
    boundPart.Anchored = true
    boundPart.CanCollide = false
    boundPart.CanTouch = false
    boundPart.CanQuery = false
    boundPart.Transparency = 1
    boundPart.Size = size + Vector3.new(1.6, 1.6, 1.6)
    boundPart.CFrame = cf
    boundPart.Parent = Workspace

    GeneratorBoundsParts[generatorModel] = boundPart
    return boundPart
end

local function ApplyGeneratorStyle(tracker)
    if not tracker or not tracker.Drawings then
        return
    end

    tracker.Color = GeneratorColor
    tracker.Name = ""

    local square = tracker.Drawings.Square
    if square and square.Drawing then
        square.Drawing.Color = GeneratorColor
        square.Drawing.Thickness = 2
        square.Visible = true
        square.Drawing.Visible = true
    end

    local distance = tracker.Drawings.Distance
    if distance and distance.Drawing then
        distance.Visible = false
        distance.Drawing.Visible = false
        distance.Function = function()
            return ""
        end
    end

    local name = tracker.Drawings.Name
    if name and name.Drawing then
        name.Visible = false
        name.Drawing.Visible = false
        name.Drawing.Text = ""
    end

    local progress = tracker.Drawings.Progress
    if progress and progress.Drawing then
        progress.Visible = true
        progress.Drawing.Visible = true
        progress.Drawing.Color = GeneratorColor
        progress.Drawing.Center = true
        progress.Drawing.Outline = true
        progress.Drawing.Size = 13
    end
end

local function EnsureGeneratorESP(generatorModel)
    if not generatorModel or not generatorModel.Parent then
        RemoveGeneratorTracker(generatorModel)
        return
    end

    if IsGeneratorComplete(generatorModel) then
        CompletedGenerators[generatorModel] = true
        RemoveGeneratorTracker(generatorModel)
        return
    end

    if CompletedGenerators[generatorModel] then
        CompletedGenerators[generatorModel] = nil
    end

    local boundsPart = GetOrCreateGeneratorBoundsPart(generatorModel)
    if not boundsPart or not boundsPart.Parent or not boundsPart.Address then
        RemoveGeneratorTracker(generatorModel)
        return
    end

    local tracker = GeneratorTrackers[generatorModel]
    if not tracker then
        local ok, newTracker = pcall(function()
            return ESP_Utility.NewTracker(boundsPart, "", GeneratorColor)
        end)

        if not ok or not newTracker then
            return
        end

        tracker = newTracker
        GeneratorTrackers[generatorModel] = tracker

        if not tracker.Drawings.Progress then
            tracker:AddText("Progress", GeneratorColor, "Generator [0%]", function()
                if not generatorModel or not generatorModel.Parent then
                    RemoveGeneratorTracker(generatorModel)
                    return ""
                end

                if IsGeneratorComplete(generatorModel) then
                    CompletedGenerators[generatorModel] = true
                    RemoveGeneratorTracker(generatorModel)
                    return ""
                end

                local progress = generatorModel:GetAttribute("Progress") or 0
                return string.format("Generator [%d%%]", progress)
            end)
        end
    end

    ApplyGeneratorStyle(tracker)
    SetTrackerVisible(tracker, UIValue("esp_master", true) and UIValue("esp_generators", true))
end

local function UpdateGenerators()
    ResetRoundIfNeeded()

    local mapsFolder = Workspace:FindFirstChild("MAPS")
    local gameMap = mapsFolder and mapsFolder:FindFirstChild("GAME MAP")
    if not gameMap then
        return
    end

    local generatorsFolder = gameMap:FindFirstChild("Generators")
    if not generatorsFolder then
        return
    end

    for _, generatorModel in ipairs(generatorsFolder:GetChildren()) do
        EnsureGeneratorESP(generatorModel)
    end

    if not (UIValue("esp_master", true) and UIValue("esp_generators", true)) then
        for generatorModel in pairs(GeneratorTrackers) do
            RemoveGeneratorTracker(generatorModel)
        end
    end
end

local function GetKillerUsername(killerModel)
    if not killerModel then
        return "Killer"
    end

    local candidates = {
        killerModel.Name,
        killerModel:GetAttribute("Player"),
        killerModel:GetAttribute("Username"),
        killerModel:GetAttribute("DisplayName"),
        killerModel:GetAttribute("Name")
    }

    for _, value in ipairs(candidates) do
        if type(value) == "string" and value ~= "" and value ~= "KILLER" and value ~= "killer" then
            return value
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character == killerModel then
            return player.Name
        end
    end

    return killerModel.Name ~= "" and killerModel.Name or "Killer"
end

local function AddOrUpdateStaticESP(instance, categoryName, color, customName, enabled)
    if not instance or not instance.Parent or not instance.Address then
        return
    end

    local bucket = StaticTrackers[categoryName]
    if not bucket then
        return
    end

    local tracker = bucket[instance]
    if not tracker then
        local ok, newTracker = pcall(function()
            return ESP_Utility.NewTracker(instance, customName or categoryName, color)
        end)

        if not ok or not newTracker then
            return
        end

        tracker = newTracker
        bucket[instance] = tracker
    end

    tracker.Color = color
    tracker.Name = customName or categoryName

    if categoryName == "Killer" then
        local name = tracker.Drawings and tracker.Drawings.Name
        if name and name.Drawing then
            name.Drawing.Color = color
            name.Drawing.Text = customName or "Killer"
            name.Visible = true
            name.Drawing.Visible = enabled
        end
    end

    SetTrackerVisible(tracker, enabled)
end

