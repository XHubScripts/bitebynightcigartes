task.spawn(function()
    while true do
        pcall(UpdateGenerators)
        task.wait(0.2)
    end
end)

task.spawn(function()
    while true do
        pcall(function()
            local master = UIValue("esp_master", true)

            local playersFolder = Workspace:FindFirstChild("PLAYERS")
            local killerFolder = playersFolder and playersFolder:FindFirstChild("KILLER")
            local killerModel = killerFolder and killerFolder:FindFirstChildWhichIsA("Model")

            if killerModel and killerModel:FindFirstChild("Hitbox") then
                local killerName = GetKillerUsername(killerModel)
                AddOrUpdateStaticESP(
                    killerModel.Hitbox,
                    "Killer",
                    KillerColor,
                    killerName,
                    master and UIValue("esp_killer", true)
                )
            end

            local pathToThings = Workspace:FindFirstChild("IGNORE")
            if not pathToThings then
                return
            end

            for _, item in ipairs(pathToThings:GetChildren()) do
                if item:IsA("BasePart") and item.Transparency == 1 then
                    continue
                end

                if item.ClassName == "Part" then
                    continue
                end

                if item.ClassName == "MeshPart" and item.MeshId ~= "rbxassetid://131427085502355" then
                    continue
                end

                if item:FindFirstChild("Trap") then
                    AddOrUpdateStaticESP(
                        item.PrimaryPart or item,
                        "Trap",
                        TrapColor,
                        "Trap",
                        master and UIValue("esp_traps", true)
                    )
                elseif item:FindFirstChild("Joint") then
                    AddOrUpdateStaticESP(
                        item.PrimaryPart or item,
                        "Battery",
                        BatteryColor,
                        "Battery",
                        master and UIValue("esp_batteries", true)
                    )
                elseif item:FindFirstChild("HumanoidRootPart") and #item:GetChildren() == 5 then
                    AddOrUpdateStaticESP(
                        item.PrimaryPart or item,
                        "Minion",
                        MinionColor,
                        "Minion",
                        master and UIValue("esp_minions", true)
                    )
                end
            end
        end)

        task.wait(2.5)
    end
end)
