pcall(function()
    loadstring(game:HttpGet(URL))()
end)

local PathToThings = game.Workspace:WaitForChild("IGNORE")

local LastCompletedGenerators = {}

local DefaultColors = {
    Generator = Color3.fromRGB(170, 85, 255),
    Battery = Color3.fromRGB(220, 232, 93),
    Trap = Color3.fromRGB(25, 0, 0),
    Minion = Color3.fromRGB(130, 55, 55),
    Killer = Color3.fromRGB(255, 150, 150),
}

local function IsEnabled(id, fallback)
    local v = UI.GetValue(id)
    if v == nil then
        return fallback
    end
    return v
end

local function GetColor(category)
    local map = {
        Generator = "esp_gen_color",
        Battery = "esp_battery_color",
        Trap = "esp_trap_color",
        Minion = "esp_minion_color",
        Killer = "esp_killer_color",
    }

    local id = map[category]
    if not id then
        return DefaultColors[category]
    end

    local value = UI.GetValue(id)
    if typeof(value) == "Color3" then
        return value
    end

    return DefaultColors[category]
end

local function Notify(title, text, duration)
    return
end

local function GetFilteredTable()
    local GameMapFolder = game.Workspace:FindFirstChild("MAPS")
    local GameMap = GameMapFolder and GameMapFolder:FindFirstChild("GAME MAP")
    if not GameMap then
        return {}
    end

    local PathToGenerators = GameMap:FindFirstChild("Generators")
    if not PathToGenerators then
        return {}
    end

    local Categories = {
        Generator = {
            Color = GetColor("Generator"),
            Objects = {},
        },
        Battery = {
            Color = GetColor("Battery"),
            Objects = {},
        },
        Trap = {
            Color = GetColor("Trap"),
            Objects = {},
        },
        Minion = {
            Color = GetColor("Minion"),
            Objects = {},
        },
        Killer = {
            Color = GetColor("Killer"),
            Objects = {},
        },
    }

    if IsEnabled("esp_generator", true) then
        for _, generatorModel in PathToGenerators:GetChildren() do
            if generatorModel.PrimaryPart then
                table.insert(Categories.Generator.Objects, generatorModel.PrimaryPart)
            end
        end
    end

    if IsEnabled("esp_killer", true) then
        local KillerFolder = game.Workspace:FindFirstChild("PLAYERS")
        KillerFolder = KillerFolder and KillerFolder:FindFirstChild("KILLER")
        local KillerModel = KillerFolder and KillerFolder:FindFirstChildWhichIsA("Model")

        if KillerModel and KillerModel:FindFirstChild("Hitbox") then
            table.insert(Categories.Killer.Objects, KillerModel.Hitbox)
        end
    end

    local PotentialObjects = {}

    for _, item in PathToThings:GetChildren() do
        local IsTransparent = item.Transparency == 1
        if IsTransparent then
            continue
        end

        local ClassName = item.ClassName
        local IsPart = ClassName == "Part"
        if IsPart then
            continue
        end

        local IsMesh = (ClassName == "MeshPart") and (item.MeshId ~= "rbxassetid://131427085502355")
        if IsMesh then
            continue
        end

        table.insert(PotentialObjects, item)
    end

    for _, item in PotentialObjects do
        local ValidChildren = {
            Trap = "Trap",
            Battery = "Joint",
            Minion = "HumanoidRootPart",
        }

        for CategoryName, ChildToLookFor in ValidChildren do
            local toggleMap = {
                Trap = "esp_trap",
                Battery = "esp_battery",
                Minion = "esp_minion",
            }

            if not IsEnabled(toggleMap[CategoryName], true) then
                continue
            end

            local FoundChild = item:FindFirstChild(ChildToLookFor)
            if FoundChild then
                if ChildToLookFor == "HumanoidRootPart" then
                    if #item:GetChildren() ~= 5 then
                        continue
                    end
                end

                local PrimaryPart = item.PrimaryPart
                table.insert(Categories[CategoryName].Objects, PrimaryPart or item)
            end
        end
    end

    return Categories
end

